{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "PINATA_JWT": "@pinata_jwt",
    "GATEWAY_URL": "@gateway_url",
    "NODE_ENV": "production",
    "ALLOWED_ORIGINS": "@allowed_origins"
  },
  "functions": {
    "core_engine.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "core_engine.js"
    },
    {
      "src": "/.*",
      "dest": "core_engine.js"
    }
  ],
  "env": {
    "VERCEL": "1"
  },
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "core_engine.js"
    }
  ]
}
