{
  "version": 2,
  "buildCommand": "npm install",
  "env": {
    "PINATA_JWT": "@pinata_jwt",
    "GATEWAY_URL": "@gateway_url",
    "NODE_ENV": "production",
    "ALLOWED_ORIGINS": "@allowed_origins"
  },
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
