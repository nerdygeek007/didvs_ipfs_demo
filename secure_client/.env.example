# ============================================
# ZERO-TRUST DOCUMENT VERIFICATION SYSTEM
# Environment Configuration
# ============================================

# PINATA API CREDENTIALS
# Generate at: https://app.pinata.cloud/developers/keys
# Required permissions: Files (Write), Pinning (pinFileToIPFS, hashMetadata), Data (pinList)
PINATA_JWT="insert_your_pinata_jwt_token_here"

# IPFS GATEWAY
# Default Pinata gateway URL
GATEWAY_URL="https://gateway.pinata.cloud/ipfs/"

# SERVER CONFIGURATION
PORT=3000
NODE_ENV="development"

# CORS CONFIGURATION
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="*"

# VERCEL SPECIFIC
# Automatically set by Vercel, no need to configure
# VERCEL=1
# VERCEL_ENV=production 
